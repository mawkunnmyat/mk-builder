{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/phy-condition-col",
	"version": "1.0.0",
	"title": "Condition Column",
	"category": "mk-builder",
	"parent": [ "mk/phy-conditions-section" ],
	"icon": "list-view",
	"description": "Single condition column (icon + heading + list of conditions) for the Physio Conditions section.",
	"keywords": [ "physio", "condition", "list", "treat", "mk" ],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "fas fa-bone"
		},
		"heading": {
			"type": "string",
			"default": "Orthopedic"
		},
		"items": {
			"type": "array",
			"default": [
				"Back & Neck Pain",
				"Arthritis & Joint Pain",
				"Post-Fracture Stiffness",
				"Spondylosis"
			]
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"iconClass": "fas fa-bone",
			"heading": "Orthopedic",
			"items": [
				"Back & Neck Pain",
				"Arthritis & Joint Pain",
				"Post-Fracture Stiffness",
				"Spondylosis"
			]
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
