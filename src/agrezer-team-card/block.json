{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/team-member",
	"version": "1.0.0",
	"title": "Team Member",
	"category": "mk-builder",
	"parent": [
		"mk/team-section"
	],
	"icon": "admin-users",
	"description": "Team member card.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": "Team member"
		},
		"name": {
			"type": "string",
			"default": ""
		},
		"role": {
			"type": "string",
			"default": ""
		},
		"profileUrl": {
			"type": "string",
			"default": ""
		},
		"profileOpenInNewTab": {
			"type": "boolean",
			"default": false
		},
		"actionAriaLabel": {
			"type": "string",
			"default": "View profile"
		},
		"showActionIcon": {
			"type": "boolean",
			"default": true
		},
		"actionIconType": {
			"type": "string",
			"default": "diagonal-arrow"
		},
		"actionBgColor": {
			"type": "string",
			"default": "#94cf37"
		},
		"actionIconColor": {
			"type": "string",
			"default": "#ffffff"
		}
	},
	"example": {
		"attributes": {
			"image": "",
			"imageAlt": "Team member portrait",
			"name": "Harry Black",
			"role": "Chief Executive Officer",
			"profileUrl": "#",
			"profileOpenInNewTab": false,
			"actionAriaLabel": "View profile"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}
