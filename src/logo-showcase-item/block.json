{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/logo-showcase-item",
	"title": "Logo Showcase Item",
	"parent": [ "mk/logo-showcase-section" ],
	"category": "mk-builder",
	"description": "Single logo cell for the logo showcase grid.",
	"keywords": [ "logo", "partner", "region", "mk" ],
	"attributes": {
		"name": {
			"type": "string",
			"default": "Mandalay Region"
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number",
			"default": 0
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"attributes": {
			"name": "Mandalay Region",
			"imageUrl": "https://images.unsplash.com/photo-1556911220-e15b29be8c8f?w=200&h=120&fit=crop&q=75",
			"imageAlt": "Mandalay Region — Shwe Myanmar"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
