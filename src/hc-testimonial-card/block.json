{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/hc-testimonial-card",
	"title": "Testimonial Card",
	"parent": [ "mk/hc-testimonials-section" ],
	"category": "mk-builder",
	"description": "Single testimonial card: stars, quote, client photo, name and location.",
	"keywords": [ "home care", "testimonial", "review", "quote", "mk" ],
	"attributes": {
		"starRating": {
			"type": "number",
			"default": 5
		},
		"review": {
			"type": "string",
			"default": "\"The home nursing team was incredible. They took care of my father like their own family. Highly recommended!\""
		},
		"clientImageId": {
			"type": "number",
			"default": 0
		},
		"clientImageUrl": {
			"type": "string",
			"default": ""
		},
		"clientImageAlt": {
			"type": "string",
			"default": "Client"
		},
		"clientName": {
			"type": "string",
			"default": "U Kyaw Swar"
		},
		"clientLocation": {
			"type": "string",
			"default": "Mandalay"
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"starRating": 5,
			"review": "\"The home nursing team was incredible. They took care of my father like their own family. Highly recommended!\"",
			"clientImageId": 0,
			"clientImageUrl": "",
			"clientImageAlt": "Client",
			"clientName": "U Kyaw Swar",
			"clientLocation": "Mandalay"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
