{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/ipd-consent-clause-item",
	"title": "IPD Consent Clause",
	"category": "mk-builder",
	"parent": [ "mk/ipd-consent-content-section" ],
	"description": "Single numbered clause for the inpatient consent document.",
	"keywords": [ "ipd", "consent", "clause", "terms", "mk" ],
