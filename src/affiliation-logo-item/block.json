{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/affiliation-logo-item",
	"title": "Logo Item",
	"parent": [ "mk/affiliations-section" ],
	"description": "Single partner/affiliation logo for the affiliations section.",
	"keywords": [ "affiliation", "partner", "logo", "mk" ],
	"attributes": {
		"logoUrl": {
			"type": "string",
			"default": ""
		},
		"logoId": {
			"type": "number"
		},
		"logoAlt": {
			"type": "string",
			"default": ""
		},
		"logoWidth": {
			"type": "number",
			"default": 0
		},
		"logoHeight": {
			"type": "number",
			"default": 0
		},
		"linkUrl": {
			"type": "string",
			"default": ""
		},
		"linkTarget": {
			"type": "string",
			"default": "_blank"
		},
		"linkRel": {
			"type": "string",
			"default": "noopener noreferrer"
		}
	},
	"example": {
		"attributes": {
			"logoUrl": "",
			"logoAlt": "",
			"logoWidth": 0,
			"logoHeight": 0,
			"linkUrl": "",
			"linkTarget": "_blank",
			"linkRel": "noopener noreferrer"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
