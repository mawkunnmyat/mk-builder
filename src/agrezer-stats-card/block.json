{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/stat-card",
	"version": "1.0.0",
	"title": "Stat Card",
	"category": "mk-builder",
	"parent": [
		"mk/stats-column"
	],
	"icon": "analytics",
	"description": "Statistic image card.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"alt": {
			"type": "string",
			"default": ""
		},
		"statValue": {
			"type": "string",
			"default": "80%"
		},
		"statLabel": {
			"type": "string",
			"default": "Efficiency"
		}
	},
	"example": {
		"attributes": {
			"image": "",
			"alt": "Corn cobs and leaves",
			"statValue": "80%",
			"statLabel": "Field Efficiency"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
