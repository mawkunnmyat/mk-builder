{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/agrezer-third-section-card",
	"version": "1.0.0",
	"title": "Agrezer Third Section Card",
	"category": "mk-builder",
	"parent": [ "mk/agrezer-third-section" ],
	"icon": "chart-bar",
	"description": "Image card with large stat and label overlay.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"stat": {
			"type": "string",
			"default": "80%"
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"cardAlign": {
			"type": "string",
			"default": "left"
		}
	},
	"example": {
		"attributes": {
			"image": "",
			"imageAlt": "Corn harvest in the field",
			"stat": "80%",
			"label": "Operational Efficiency",
			"cardAlign": "left"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
