{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/agrezer-partners-section",
	"version": "1.0.0",
	"title": "Agrezer Partners Marquee",
	"category": "mk-builder",
	"icon": "slides",
	"description": "Infinite-scrolling partner logos row (marquee).",
	"keywords": [
		"partners",
		"logos",
		"marquee",
		"clients",
		"agrezer",
		"mk"
	],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"ariaLabel": {
			"type": "string",
			"default": "Client logos"
		},
		"marqueePaddingY": {
			"type": "number",
			"default": 64
		},
		"borderColor": {
			"type": "string",
			"default": "rgba(18, 24, 18, 0.08)"
		},
		"trackGap": {
			"type": "number",
			"default": 64
		},
		"animationDuration": {
			"type": "number",
			"default": 20
		},
		"enableMarquee": {
			"type": "boolean",
			"default": true
		},
		"pauseOnHover": {
			"type": "boolean",
			"default": true
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#ffffff",
			"ariaLabel": "Partner and client logos",
			"marqueePaddingY": 48,
			"borderColor": "rgba(18, 24, 18, 0.08)",
			"trackGap": 56,
			"animationDuration": 20,
			"enableMarquee": true,
			"pauseOnHover": true
		},
		"innerBlocks": [
			{
				"name": "mk/agrezer-partners-item",
				"attributes": {
					"name": "NatureNest",
					"image": "",
					"imageAlt": "NatureNest logo"
				}
			},
			{
				"name": "mk/agrezer-partners-item",
				"attributes": {
					"name": "GreenLeaf Co-op",
					"image": "",
					"imageAlt": "GreenLeaf Co-op logo"
				}
			},
			{
				"name": "mk/agrezer-partners-item",
				"attributes": {
					"name": "PureHarvest",
					"image": "",
					"imageAlt": "PureHarvest logo"
				}
			},
			{
				"name": "mk/agrezer-partners-item",
				"attributes": {
					"name": "AgroNova",
					"image": "",
					"imageAlt": "AgroNova logo"
				}
			},
			{
				"name": "mk/agrezer-partners-item",
				"attributes": {
					"name": "Field & Fork",
					"image": "",
					"imageAlt": "Field and Fork logo"
				}
			}
		]
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
