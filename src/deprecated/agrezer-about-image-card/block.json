{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/agrezer-about-image-card",
	"version": "1.0.0",
	"title": "Agrezer About Image Card",
	"category": "mk-builder",
	"parent": [ "mk/agrezer-about-images-grid" ],
	"icon": "format-image",
	"description": "Image card — plain or with overlay CTA.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"variant": {
			"type": "string",
			"default": "simple"
		},
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"alt": {
			"type": "string",
			"default": ""
		},
		"overlayText": {
			"type": "string",
			"default": "Agriculture nurtures life through organic growth, sustainable farming."
		},
		"overlayButtonText": {
			"type": "string",
			"default": "About Us"
		},
		"overlayButtonUrl": {
			"type": "string",
			"default": "#"
		}
	},
	"example": {
		"attributes": {
			"variant": "overlay",
			"image": "",
			"alt": "Farmer inspecting healthy crops",
			"overlayText": "Agriculture nurtures life through organic growth, sustainable farming, and careful stewardship of the land.",
			"overlayButtonText": "About Us",
			"overlayButtonUrl": "#"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
