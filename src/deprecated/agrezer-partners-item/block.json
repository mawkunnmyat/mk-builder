{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/agrezer-partners-item",
	"version": "1.0.0",
	"title": "Agrezer Partner Logo",
	"category": "mk-builder",
	"parent": [ "mk/agrezer-partners-section" ],
	"icon": "admin-users",
	"description": "Single partner logo and name in the marquee.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"name": {
			"type": "string",
			"default": ""
		}
	},
	"example": {
		"attributes": {
			"name": "NatureNest",
			"image": "",
			"imageAlt": "NatureNest partner logo"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
