{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/intro-feature",
	"version": "1.0.0",
	"title": "Intro Feature",
	"category": "mk-builder",
	"parent": [
		"mk/intro-section"
	],
	"icon": "star-filled",
	"description": "Small feature label (intro list item).",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		}
	},
	"example": {
		"attributes": {
			"image": "",
			"imageAlt": "Feature icon",
			"label": "World Class Services"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
