{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/centre-doctor-card",
	"version": "1.0.0",
	"title": "Doctor Card (Mini)",
	"category": "mk-builder",
	"parent": [ "mk/centre-doctors-section" ],
	"description": "Single specialist/doctor card with photo, name, specialization, and profile link.",
	"attributes": {
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"name": {
			"type": "string",
			"default": "Dr. Susan May"
		},
		"specialization": {
			"type": "string",
			"default": "Neurosurgeon"
		},
		"profileUrl": {
			"type": "string",
			"default": "doctor-profile.html"
		},
		"profileLinkText": {
			"type": "string",
			"default": "View Profile"
		}
	},
	"editorScript": "file:./index.js",
	"example": {
		"attributes": {
			"imageUrl": "",
			"imageAlt": "",
			"name": "Dr. Susan May",
			"specialization": "Neurosurgeon",
			"profileUrl": "doctor-profile.html",
			"profileLinkText": "View Profile"
		}
	}
}
