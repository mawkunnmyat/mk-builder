{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/visitor-guidelines-section",
	"title": "Visitor Guidelines Section",
	"category": "mk-builder",
	"description": "Visitor guidelines section with Do's and Don'ts columns for patient guide.",
	"keywords": [
		"visitor",
		"guidelines",
		"dos",
		"donts",
		"patient",
		"guide",
		"mk"
	],
	"icon": "list-view",
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number"
		},
		"backgroundOverlay": {
			"type": "boolean",
			"default": false
		},
		"backgroundOverlayColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.5)"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 0.5
		},
		"paddingTop": {
			"type": "number",
			"default": 80
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"paddingTopMobile": {
			"type": "number",
			"default": 60
		},
		"paddingBottomMobile": {
			"type": "number",
			"default": 60
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "number",
			"default": 40
		},
		"gapMobile": {
			"type": "number",
			"default": 30
		},
		"showSectionTitle": {
			"type": "boolean",
			"default": true
		},
		"sectionTitle": {
			"type": "string",
			"default": "Visitor Guidelines"
		},
		"sectionTitleColor": {
			"type": "string",
			"default": "#212121"
		},
		"sectionTitleFontSize": {
			"type": "number",
			"default": 2
		},
		"sectionTitleFontSizeMobile": {
			"type": "number",
			"default": 1.6
		},
		"sectionTitleFontWeight": {
			"type": "number",
			"default": 700
		},
		"sectionTitleAlignment": {
			"type": "string",
			"default": "center"
		},
		"showSectionSubtitle": {
			"type": "boolean",
			"default": false
		},
		"sectionSubtitle": {
			"type": "string",
			"default": "Please follow these guidelines to ensure a comfortable visit for everyone."
		},
		"sectionSubtitleColor": {
			"type": "string",
			"default": "#666666"
		},
		"sectionSubtitleFontSize": {
			"type": "number",
			"default": 1.05
		},
		"sectionSubtitleFontSizeMobile": {
			"type": "number",
			"default": 0.95
		},
		"sectionHeaderMaxWidth": {
			"type": "number",
			"default": 700
		},
		"sectionHeaderMarginBottom": {
			"type": "number",
			"default": 50
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"containerPaddingMobile": {
			"type": "number",
			"default": 20
		},
		"animationOnScroll": {
			"type": "boolean",
			"default": true
		},
		"animationDelay": {
			"type": "number",
			"default": 100
		},
		"animationType": {
			"type": "string",
			"default": "fadeInUp"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#ffffff",
			"backgroundImage": "",
			"backgroundOverlay": false,
			"backgroundOverlayColor": "rgba(0, 0, 0, 0.5)",
			"backgroundOverlayOpacity": 0.5,
			"paddingTop": 80,
			"paddingBottom": 80,
			"paddingTopMobile": 60,
			"paddingBottomMobile": 60,
			"columns": 2,
			"columnsMobile": 1,
			"gap": 40,
			"gapMobile": 30,
			"showSectionTitle": true,
			"sectionTitle": "Visitor Guidelines",
			"sectionTitleColor": "#212121",
			"sectionTitleFontSize": 2,
			"sectionTitleFontSizeMobile": 1.6,
			"sectionTitleFontWeight": 700,
			"sectionTitleAlignment": "center",
			"showSectionSubtitle": false,
			"sectionSubtitle": "Please follow these guidelines to ensure a comfortable visit for everyone.",
			"sectionSubtitleColor": "#666666",
			"sectionSubtitleFontSize": 1.05,
			"sectionSubtitleFontSizeMobile": 0.95,
			"sectionHeaderMaxWidth": 700,
			"sectionHeaderMarginBottom": 50,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"containerPaddingMobile": 20,
			"animationOnScroll": true,
			"animationDelay": 100,
			"animationType": "fadeInUp"
		},
		"innerBlocks": [
			{
				"name": "mk/visitor-guidelines-column",
				"attributes": {
					"columnType": "dos",
					"title": "Do's",
					"titleIcon": "fas fa-check-circle",
					"itemIcon": "fas fa-check",
					"listItems": [
						{
							"id": 1,
							"text": "Wear a mask at all times within the premises."
						},
						{
							"id": 2,
							"text": "Sanitize your hands before entering the ward."
						},
						{
							"id": 3,
							"text": "Keep your mobile phones on silent mode."
						},
						{
							"id": 4,
							"text": "Respect the privacy of other patients."
						}
					]
				}
			},
			{
				"name": "mk/visitor-guidelines-column",
				"attributes": {
					"columnType": "donts",
					"title": "Don'ts",
					"titleIcon": "fas fa-times-circle",
					"itemIcon": "fas fa-times",
					"listItems": [
						{
							"id": 1,
							"text": "Do not bring outside food or flowers."
						},
						{
							"id": 2,
							"text": "Children under 12 are not advised to visit."
						},
						{
							"id": 3,
							"text": "Do not smoke or consume alcohol on premises."
						},
						{
							"id": 4,
							"text": "Do not make loud noises in the corridors."
						}
					]
				}
			}
		]
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
