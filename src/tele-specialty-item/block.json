{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/tele-specialty-item",
	"title": "Specialty Item",
	"parent": [ "mk/tele-specialty-section" ],
	"category": "mk-builder",
	"icon": "admin-generic",
	"description": "Single specialty card (icon + title) for Tele Specialty section.",
	"keywords": [ "specialty", "telemedicine", "card", "icon", "mk" ],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "fas fa-stethoscope"
		},
		"title": {
			"type": "string",
			"default": "General Medicine"
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"attributes": {
			"iconClass": "fas fa-stethoscope",
			"title": "General Medicine"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
