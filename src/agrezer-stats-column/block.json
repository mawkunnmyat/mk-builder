{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/stats-column",
	"version": "1.0.0",
	"title": "Stats Column",
	"category": "mk-builder",
	"parent": [
		"mk/stats-section"
	],
	"icon": "columns",
	"description": "Column container for stats cards/CTA.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"innerBlocks": [
			{
				"name": "mk/cta-block",
				"attributes": {
					"buttonText": "Get In Touch",
					"buttonUrl": "#"
				}
			},
			{
				"name": "mk/stat-card",
				"attributes": {
					"image": "",
					"alt": "Harvest detail",
					"statValue": "98%",
					"statLabel": "Increase in Yields"
				}
			}
		]
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
