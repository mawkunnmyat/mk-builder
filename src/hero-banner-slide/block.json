{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/hero-banner-slide",
	"version": "1.0.0",
	"title": "Hero Banner Slide",
	"category": "mk-builder",
	"icon": "format-image",
	"description": "Single hero slide for the Hero Banner Carousel block.",
	"parent": [ "mk/hero-banner-carousel" ],
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"eyebrow": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": ""
		},
		"subtitle": {
			"type": "string",
			"default": ""
		},
		"ctaLabel": {
			"type": "string",
			"default": ""
		},
		"ctaHref": {
			"type": "string",
			"default": "#"
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"backgroundPosition": {
			"type": "string",
			"default": "center right"
		},
		"headingLevel": {
			"type": "string",
			"default": "h2",
			"enum": [ "h1", "h2" ]
		}
	},
	"example": {
		"attributes": {
			"eyebrow": "SHWE MYANMAR FOODSTUFF INDUSTRY",
			"title": "သဘာဝ အနံ့ သဘာဝ အရသာ...",
			"subtitle": "Natural scent, natural taste — premium butter and ghee crafted in Mandalay, Myanmar.",
			"ctaLabel": "VIEW PRODUCTS",
			"ctaHref": "#categories",
			"imageAlt": "Premium golden butter and ghee",
			"imageUrl": "",
			"backgroundPosition": "right center"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
