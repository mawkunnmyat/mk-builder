{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/doctor-card-item",
	"title": "Doctor Card Item",
	"parent": [ "mk/doctor-directory-section" ],
	"description": "Single doctor card for the Doctor Directory. Used inside Doctor Directory Section.",
	"keywords": [ "doctor", "card", "profile", "mk" ],
	"attributes": {
		"doctorImage": {
			"type": "string",
			"default": ""
		},
		"doctorImageId": {
			"type": "number"
		},
		"imageHeight": {
			"type": "number",
			"default": 260
		},
		"imageObjectFit": {
			"type": "string",
			"default": "cover"
		},
		"imageObjectPosition": {
			"type": "string",
			"default": "top center"
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"showBadge": {
			"type": "boolean",
			"default": false
		},
		"badgeText": {
			"type": "string",
			"default": "Available Today"
		},
		"departmentSlug": {
			"type": "string",
			"default": "heart"
		},
		"departmentLabel": {
			"type": "string",
			"default": "Heart Centre"
		},
		"doctorName": {
			"type": "string",
			"default": "Dr. Kyaw Swar"
		},
		"qualifications": {
			"type": "string",
			"default": "MBBS, M.Med.Sc, MRCP (UK)"
		},
		"gender": {
			"type": "string",
			"default": "male"
		},
		"profileUrl": {
			"type": "string",
			"default": "#"
		},
		"profileOpenInNewTab": {
			"type": "boolean",
			"default": false
		},
		"bookUrl": {
			"type": "string",
			"default": "#"
		},
		"bookOpenInNewTab": {
			"type": "boolean",
			"default": false
		},
		"profileButtonText": {
			"type": "string",
			"default": "Profile"
		},
		"bookButtonText": {
			"type": "string",
			"default": "Book"
		},
		"showButtons": {
			"type": "boolean",
			"default": true
		},
		"showProfileButton": {
			"type": "boolean",
			"default": true
		},
		"showBookButton": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false
	},
	"usesContext": [ "mk/departments", "mk/genders" ],
	"example": {
		"attributes": {
			"doctorImage": "",
			"imageHeight": 260,
			"imageObjectFit": "cover",
			"imageObjectPosition": "top center",
			"showImage": true,
			"showBadge": false,
			"badgeText": "Available Today",
			"departmentSlug": "heart",
			"departmentLabel": "Heart Centre",
			"doctorName": "Dr. Kyaw Swar",
			"qualifications": "MBBS, M.Med.Sc, MRCP (UK)",
			"gender": "male",
			"profileUrl": "#",
			"profileOpenInNewTab": false,
			"bookUrl": "#",
			"bookOpenInNewTab": false,
			"profileButtonText": "Profile",
			"bookButtonText": "Book",
			"showButtons": true,
			"showProfileButton": true,
			"showBookButton": true
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./style-index.css"
}
