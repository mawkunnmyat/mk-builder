{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/gm-service-item",
	"title": "Service Item",
	"category": "mk-builder",
	"parent": [ "mk/gm-services-section" ],
	"attributes": {
		"icon": {
			"type": "string",
			"default": "fas fa-thermometer-half"
		},
		"title": {
			"type": "string",
			"default": "Service Title"
		},
		"description": {
			"type": "string",
			"default": "Service description goes here."
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"attributes": {
			"icon": "fas fa-thermometer-half",
			"title": "Service Title",
			"description": "Service description goes here."
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
