{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/testimonial",
	"version": "1.0.0",
	"title": "Testimonial",
	"category": "mk-builder",
	"parent": [
		"mk/testimonials"
	],
	"icon": "format-quote",
	"description": "Single testimonial slide/card.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"quote": {
			"type": "string",
			"default": ""
		},
		"authorName": {
			"type": "string",
			"default": ""
		},
		"authorRole": {
			"type": "string",
			"default": ""
		},
		"rating": {
			"type": "number",
			"default": 5
		}
	},
	"example": {
		"attributes": {
			"quote": "Agrezer helped us cut input waste while improving tonnage—clear reporting and a team that actually picks up the phone.",
			"authorName": "Alex Robin",
			"authorRole": "Co-Founder",
			"rating": 5
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
