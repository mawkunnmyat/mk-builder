{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/phy-stat-card",
	"version": "1.0.0",
	"title": "Stat Card",
	"category": "mk-builder",
	"parent": [ "mk/phy-stats-section" ],
	"icon": "minus",
	"description": "Single stat card: number + label (e.g. 5k+ Happy Patients). Use inside Physio Stats Section.",
	"keywords": [ "physio", "stat", "card", "number", "mk" ],
	"attributes": {
		"statNumber": {
			"type": "string",
			"default": "5k+"
		},
		"label": {
			"type": "string",
			"default": "Happy Patients"
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"statNumber": "5k+",
			"label": "Happy Patients"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
