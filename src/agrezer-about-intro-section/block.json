{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/intro-section",
	"version": "1.0.0",
	"title": "Intro Section",
	"category": "mk-builder",
	"icon": "welcome-learn-more",
	"description": "Intro section with media and feature list.",
	"keywords": [
		"about",
		"intro",
		"agriculture",
		"mk"
	],
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"anchor": true
	},
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#FFFFFF"
		},
		"paddingTop": {
			"type": "number",
			"default": 120
		},
		"paddingBottom": {
			"type": "number",
			"default": 120
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerWidthPct": {
			"type": "number",
			"default": 90
		},
		"columnGap": {
			"type": "number",
			"default": 80
		},
		"mainImage": {
			"type": "string",
			"default": ""
		},
		"mainImageId": {
			"type": "number"
		},
		"mainImageAlt": {
			"type": "string",
			"default": ""
		},
		"subImage": {
			"type": "string",
			"default": ""
		},
		"subImageId": {
			"type": "number"
		},
		"subImageAlt": {
			"type": "string",
			"default": ""
		},
		"badgeImage": {
			"type": "string",
			"default": ""
		},
		"badgeImageId": {
			"type": "number"
		},
		"badgeImageAlt": {
			"type": "string",
			"default": ""
		},
		"showShape": {
			"type": "boolean",
			"default": true
		},
		"shapeColor": {
			"type": "string",
			"default": "#DCE55D"
		},
		"showBadge": {
			"type": "boolean",
			"default": true
		},
		"enableBadgeSpin": {
			"type": "boolean",
			"default": true
		},
		"tagIcon": {
			"type": "string",
			"default": ""
		},
		"tagIconId": {
			"type": "number"
		},
		"tagIconAlt": {
			"type": "string",
			"default": ""
		},
		"tagline": {
			"type": "string",
			"default": "Get To Know Us"
		},
		"title": {
			"type": "string",
			"default": "We Care About Your Business &amp; Agriculture"
		},
		"description": {
			"type": "string",
			"default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s."
		},
		"authorImage": {
			"type": "string",
			"default": ""
		},
		"authorImageId": {
			"type": "number"
		},
		"authorImageAlt": {
			"type": "string",
			"default": ""
		},
		"authorName": {
			"type": "string",
			"default": "Sanoat"
		},
		"authorRole": {
			"type": "string",
			"default": "CEO &amp; Founder"
		},
		"signatureText": {
			"type": "string",
			"default": "Sanoat"
		},
		"signatureColor": {
			"type": "string",
			"default": "#8BC34A"
		},
		"signatureFontSize": {
			"type": "number",
			"default": 2
		},
		"signatureFontFamily": {
			"type": "string",
			"default": "'Brush Script MT', cursive"
		}
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"backgroundColor": "#FFFFFF",
			"paddingTop": 96,
			"paddingBottom": 96,
			"containerMaxWidth": 1200,
			"containerWidthPct": 90,
			"columnGap": 72,
			"mainImage": "",
			"mainImageAlt": "Farmer walking through a green field",
			"subImage": "",
			"subImageAlt": "Hands holding fresh produce",
			"badgeImage": "",
			"badgeImageAlt": "Organic certification seal style graphic",
			"showShape": true,
			"shapeColor": "#DCE55D",
			"showBadge": true,
			"enableBadgeSpin": true,
			"tagline": "Get To Know Us",
			"title": "We Care About Your Business &amp; Agriculture",
			"description": "From soil testing to harvest logistics, our agronomists partner with growers to improve yield, quality, and long-term land health—season after season.",
			"authorImage": "",
			"authorImageAlt": "Portrait of company founder",
			"authorName": "Jordan Ellis",
			"authorRole": "CEO &amp; Founder",
			"signatureText": "Jordan Ellis",
			"signatureColor": "#8BC34A",
			"signatureFontSize": 2,
			"signatureFontFamily": "'Brush Script MT', cursive"
		},
		"innerBlocks": [
			{
				"name": "mk/intro-feature",
				"attributes": {
					"image": "",
					"imageAlt": "Leaf icon",
					"label": "World Class Services"
				}
			},
			{
				"name": "mk/intro-feature",
				"attributes": {
					"image": "",
					"imageAlt": "Vegetables icon",
					"label": "Fresh Organic Foods"
				}
			},
			{
				"name": "mk/intro-feature",
				"attributes": {
					"image": "",
					"imageAlt": "Grains icon",
					"label": "100% Quality Foods"
				}
			},
			{
				"name": "mk/intro-feature",
				"attributes": {
					"image": "",
					"imageAlt": "Farm icon",
					"label": "Professional Farmers"
				}
			}
		]
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
