{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/process-center",
	"version": "1.0.0",
	"title": "Process Center",
	"category": "mk-builder",
	"parent": [
		"mk/process"
	],
	"icon": "format-image",
	"description": "Center element in a process timeline/steps layout.",
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"image": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number"
		},
		"alt": {
			"type": "string",
			"default": "Process Wheel"
		},
		"maxWidth": {
			"type": "number",
			"default": 560
		}
	},
	"example": {
		"attributes": {
			"image": "",
			"alt": "Hands holding soil and seedlings",
			"maxWidth": 520
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
