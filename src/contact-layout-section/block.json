{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/contact-layout-section",
	"version": "1.0.0",
	"title": "Contact Layout Section",
	"category": "mk-builder",
	"icon": "layout",
	"description": "Contact page section: left column (department hotlines accordion + map), right column (contact form).",
	"keywords": [ "contact", "accordion", "hotline", "map", "form", "mk" ],
	"attributes": {
		"accordionHeading": {
			"type": "string",
			"default": "Direct Department Lines"
		},
		"locationHeading": {
			"type": "string",
			"default": "Our Location"
		},
		"locationHeadingMarginTop": {
			"type": "number",
			"default": 40
		},
		"mapEmbedUrl": {
			"type": "string",
			"default": ""
		},
		"mapHeight": {
			"type": "number",
			"default": 350
		},
		"formTitle": {
			"type": "string",
			"default": "Send us a Message"
		},
		"formNameLabel": {
			"type": "string",
			"default": "Full Name"
		},
		"formPhoneLabel": {
			"type": "string",
			"default": "Phone Number"
		},
		"formMessageLabel": {
			"type": "string",
			"default": "Your Message"
		},
		"buttonText": {
			"type": "string",
			"default": "Send Message"
		},
		"formId": {
			"type": "string",
			"default": "contactForm"
		},
		"layoutGap": {
			"type": "number",
			"default": 60
		},
		"containerMaxWidth": {
			"type": "number",
			"default": 1200
		},
		"containerPadding": {
			"type": "number",
			"default": 20
		},
		"paddingBottom": {
			"type": "number",
			"default": 80
		},
		"primaryColor": {
			"type": "string",
			"default": "#f48b2a"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"example": {
		"viewportWidth": 1200,
		"attributes": {
			"accordionHeading": "Direct Department Lines",
			"locationHeading": "Our Location",
			"locationHeadingMarginTop": 40,
			"mapEmbedUrl": "",
			"mapHeight": 350,
			"formTitle": "Send us a Message",
			"formNameLabel": "Full Name",
			"formPhoneLabel": "Phone Number",
			"formMessageLabel": "Your Message",
			"buttonText": "Send Message",
			"formId": "contactForm",
			"layoutGap": 60,
			"containerMaxWidth": 1200,
			"containerPadding": 20,
			"paddingBottom": 80,
			"primaryColor": "#f48b2a"
		},
		"innerBlocks": [
			{
				"name": "mk/hotline-accordion-item",
				"attributes": {
					"title": "Heart Centre Hotline",
					"phoneNumber": "09-111 222 333"
				}
			},
			{
				"name": "mk/hotline-accordion-item",
				"attributes": {
					"title": "Neuro Centre Hotline",
					"phoneNumber": "09-444 555 666"
				}
			},
			{
				"name": "mk/hotline-accordion-item",
				"attributes": {
					"title": "Pharmacy & Lab",
					"phoneNumber": "09-777 888 999"
				}
			}
		]
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./style-index.css"
}
