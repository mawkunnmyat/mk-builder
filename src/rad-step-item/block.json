{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/rad-step-item",
	"version": "1.0.0",
	"title": "Process Step",
	"parent": [ "mk/rad-process-section" ],
	"category": "mk-builder",
	"description": "Single workflow step (icon, title, description) for the Radiology Process Section.",
	"keywords": [ "radiology", "process", "step", "mk" ],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "far fa-calendar-check"
		},
		"title": {
			"type": "string",
			"default": "Book"
		},
		"description": {
			"type": "string",
			"default": "Schedule via phone or app."
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"iconClass": "far fa-calendar-check",
			"title": "Book",
			"description": "Schedule via phone or app."
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
