{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/category-card",
	"title": "Category Card",
	"parent": [ "mk/category-card-grid" ],
	"category": "mk-builder",
	"description": "Single product category card with image, title, and count.",
	"keywords": [ "category", "product", "card", "shop", "mk" ],
	"attributes": {
		"title": {
			"type": "string",
			"default": "Butter"
		},
		"count": {
			"type": "string",
			"default": "3 Sizes"
		},
		"href": {
			"type": "string",
			"default": "/pages/shop.html"
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number",
			"default": 0
		},
		"imageAlt": {
			"type": "string",
			"default": "Shwe Myanmar Butter"
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	},
	"example": {
		"attributes": {
			"title": "Butter",
			"count": "3 Sizes",
			"href": "/pages/shop.html",
			"imageUrl": "",
			"imageAlt": "Shwe Myanmar Butter"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
