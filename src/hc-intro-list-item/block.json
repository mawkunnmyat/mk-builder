{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/hc-intro-list-item",
	"title": "Intro List Item",
	"parent": [ "mk/hc-intro-section" ],
	"category": "mk-builder",
	"description": "Single checklist item (icon + text) for the Home Care Intro section.",
	"keywords": [ "home care", "intro", "list", "checklist", "mk" ],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "fas fa-check-circle"
		},
		"text": {
			"type": "string",
			"default": "List item"
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"iconClass": "fas fa-check-circle",
			"text": "List item"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js"
}
