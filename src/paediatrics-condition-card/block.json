{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mk/paediatrics-condition-card",
	"version": "1.0.0",
	"title": "Condition Card",
	"category": "mk-builder",
	"parent": [ "mk/paediatrics-conditions-section" ],
	"icon": "heart",
	"description": "Single condition card (icon, title, subtitle) for Paediatrics Conditions section.",
	"keywords": [ "paediatrics", "condition", "card", "mk" ],
	"attributes": {
		"iconClass": {
			"type": "string",
			"default": "fas fa-lungs"
		},
		"title": {
			"type": "string",
			"default": "Respiratory Issues"
		},
		"subtitle": {
			"type": "string",
			"default": "Asthma, Pneumonia"
		}
	},
	"supports": {
		"html": false
	},
	"example": {
		"attributes": {
			"iconClass": "fas fa-lungs",
			"title": "Respiratory Issues",
			"subtitle": "Asthma, Pneumonia"
		}
	},
	"textdomain": "mk-builder",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
